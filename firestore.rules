rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny blanket gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive validator helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Predictions document validation blueprint
    function isValidPrediction(data) {
      return data.keys().hasAll(['id', 'name', 'matchId', 'predictedScoreA', 'predictedScoreB', 'firstGoalscorer', 'timestamp'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.matchId is string && data.matchId.size() <= 128
        && data.predictedScoreA is string && data.predictedScoreA.size() <= 10
        && data.predictedScoreB is string && data.predictedScoreB.size() <= 10
        && data.firstGoalscorer is string && data.firstGoalscorer.size() <= 128
        && data.timestamp is string && data.timestamp.size() <= 64;
    }

    match /predictions/{predictionId} {
      allow read, list: if true;
      allow create: if isValidId(predictionId) && isValidPrediction(incoming());
      allow update: if isValidId(predictionId) && isValidPrediction(incoming()) 
        && (incoming().diff(existing()).affectedKeys().hasOnly(['isGolden', 'goldenMessage', 'tipAmount', 'status', 'outcomeScoreA', 'outcomeScoreB', 'scoreMatched', 'goalscorerMatched']));
      allow delete: if isValidId(predictionId);
    }

    // Outcomes document validation blueprint
    function isValidOutcome(data) {
      return data.keys().hasAll(['matchId', 'actualScoreA', 'actualScoreB', 'resolved'])
        && data.matchId is string && data.matchId.size() <= 128
        && data.actualScoreA is string && data.actualScoreA.size() <= 10
        && data.actualScoreB is string && data.actualScoreB.size() <= 10
        && data.resolved is bool;
    }

    match /outcomes/{outcomeId} {
      allow read, list: if true;
      allow create, update: if isValidId(outcomeId) && isValidOutcome(incoming());
      allow delete: if isValidId(outcomeId);
    }
  }
}
