# GEMINI_API_KEY: Required for Gemini AI API calls.
# Configure this key in your environment secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase project URL.
# Find this in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase service role secret key (server-side only).
# Find this in: Supabase Dashboard → Settings → API → service_role key
# WARNING: Never expose this key in the browser/frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# DODO_PAYMENTS_API_KEY: Secret API bearer token from Dodo Payments dashboard.
DODO_PAYMENTS_API_KEY=

# DODO_PAYMENTS_ENV: Set to 'sandbox' or 'live'
DODO_PAYMENTS_ENV=sandbox

# DODO_PAYMENTS_GOLD_PRODUCT_ID: Product ID for Gold parlay surcharge upgrades.
DODO_PAYMENTS_GOLD_PRODUCT_ID=

# DODO_PAYMENTS_TIP_PRODUCT_ID: Product ID for custom tips.
DODO_PAYMENTS_TIP_PRODUCT_ID=

